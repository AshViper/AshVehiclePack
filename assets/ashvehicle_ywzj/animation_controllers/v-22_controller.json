			"states": {
				"init": {
					"on_enter": [
						{
							"type": "play_animation",
							"animation": "highspeed_on",
							"play_type": "play_once_hold",
							"track": "highspeed_on"
						},
						{
							"type": "play_animation",
							"animation": "highspeed_off",
							"play_type": "play_once_hold",
							"track": "highspeed_off"
						}
					],
					"transitions": [
						{
							"target": "highspeed_on",
							"condition": {
								"type": "script",
								"script": "context.getSpeed() > 1.6"
							},
							"duration": 2
						}
					],
					"evaluate": {
						"type": "track",
						"track": ""
					}
				},
				"highspeed_off": {
					"transitions": [
						{
							"target": "highspeed_on",
							"condition": {
								"type": "script",
								"script": "context.getSpeed() > 1.6"
							},
							"duration": 2
						}
					],
					"evaluate": {
						"type": "track",
						"track": "highspeed_off"
					}
				},
				"highspeed_on": {
					"transitions": [
						{
							"target": "highspeed_off",
							"condition": {
								"type": "script",
								"script": "context.getSpeed() < 1.6"
							},
							"duration": 2
						}
					],
					"evaluate": {
						"type": "track",
						"track": "highspeed_on"
					}
				}
			}
		}
	},
	"graph": {
		"type": "merge",
		"inputs": [
			{
				"type": "switchable_animation",
				"ref": "landing_gear"
			},
			{
				"type": "state_machine",
				"ref": "variable_sweep_wing"
			},
			{
				"type": "script",
				"function": "updateBones"
			}
		]
	}
}
